---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang: Lang;
  availableLangs?: Lang[];
  view?: 'reading' | 'profile';
}

const { lang, availableLangs, view = 'reading' } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
const profilePath = `/${lang}/trayectoria/`;
const languagePaths = view === 'profile'
  ? { es: '/es/trayectoria/', en: '/en/trayectoria/', de: '/de/trayectoria/' }
  : undefined;
---

<header class="site-header">
  <div class="container">
    <div class="site-header__inner">
      <a href={`${basePath}/`} class="site-header__name">José Arbelaez</a>
      <div class="site-header__controls">
        <LanguageSwitcher lang={lang} availableLangs={availableLangs} paths={languagePaths} />
        <nav class="site-view-switcher" aria-label={t.views.label}>
          <a
            href={`${basePath}/`}
            class:list={["site-view-switcher__link", { "site-view-switcher__link--active": view === 'reading' }]}
            aria-label={t.views.reading}
            aria-current={view === 'reading' ? 'page' : undefined}
            title={t.views.reading}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 7v14"></path>
              <path d="M3 18a1 1 0 0 1-1-1V5a2 2 0 0 1 2-2h5a3 3 0 0 1 3 3v15a3 3 0 0 0-3-3Z"></path>
              <path d="M21 18a1 1 0 0 0 1-1V5a2 2 0 0 0-2-2h-5a3 3 0 0 0-3 3v15a3 3 0 0 1 3-3Z"></path>
            </svg>
          </a>
          <a
            href={profilePath}
            class:list={["site-view-switcher__link", { "site-view-switcher__link--active": view === 'profile' }]}
            aria-label={t.views.profile}
            aria-current={view === 'profile' ? 'page' : undefined}
            title={t.views.profile}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 8V4H8"></path>
              <rect width="16" height="12" x="4" y="8" rx="2"></rect>
              <path d="M2 14h2"></path>
              <path d="M20 14h2"></path>
              <path d="M9 13v2"></path>
              <path d="M15 13v2"></path>
            </svg>
          </a>
        </nav>
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>
