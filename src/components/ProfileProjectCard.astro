---
import type { ProfileProject } from '../data/profile.es';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  project: ProfileProject;
  lang: Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const dialogId = `project-preview-${project.id}`;
const titleId = `${dialogId}-title`;
const galleryTitleId = `${dialogId}-gallery-title`;
const carouselTitleId = `${dialogId}-carousel-title`;
---

<article class="profile-project-card" data-project-card>
  <button
    class="profile-project-card__main"
    type="button"
    aria-haspopup="dialog"
    aria-controls={dialogId}
    aria-label={`${t.profile.open_project}: ${project.title}`}
    data-project-preview-open
  ></button>

  {project.year && <span class="profile-project-card__year">{project.year}</span>}

  <h3 class="profile-project-card__title">{project.title}</h3>
  {project.excerpt && <p class="profile-project-card__excerpt">{project.excerpt}</p>}

  <div class="profile-project-card__links" aria-hidden="true">
    <span>{t.profile.open_project}</span>
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 14 14 6"></path>
      <path d="M7 6h7v7"></path>
    </svg>
  </div>

  <dialog
    class="project-preview"
    id={dialogId}
    aria-labelledby={titleId}
    data-project-preview-dialog
  >
    <div class="project-preview__shell">
      <div class="project-preview__content" data-project-preview-content>
        <header class="project-preview__topbar">
          <div class="project-preview__identity">
            <strong id={titleId}>{project.title}</strong>
            {project.year && <span>{project.year}</span>}
          </div>
          <button
            class="project-preview__close"
            type="button"
            aria-label={t.profile.close_project}
            title={t.profile.close_project}
            data-project-preview-close
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </header>

        <div class="project-preview__layout">
          <section class="project-preview__gallery" aria-labelledby={galleryTitleId}>
            <header class="project-preview__gallery-header">
              <h3 id={galleryTitleId}>{t.profile.gallery}</h3>
              {project.gallery && project.gallery.length > 0 && <span>{project.gallery.length}</span>}
            </header>

            {project.gallery && project.gallery.length > 0 ? (
              <div class="project-preview__collage">
                {project.gallery.map((image, index) => (
                  <button
                    class="project-collage__item"
                    type="button"
                    aria-label={`${t.profile.open_image} ${index + 1}`}
                    data-carousel-index={index}
                    data-carousel-caption={image.caption}
                  >
                    <img
                      src={image.src}
                      alt={image.alt}
                      loading={index < 6 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  </button>
                ))}
              </div>
            ) : (
              <div class="project-preview__gallery-empty">
                <p>{t.profile.gallery_empty}</p>
              </div>
            )}
          </section>

          <aside class="project-preview__story">
            <section class="project-preview__article" aria-label={t.profile.article_preview}>
              <p class="project-preview__eyebrow">{t.profile.article_preview}</p>

              {project.articleHref ? (
                <div class="project-preview__article-frame">
                  <iframe
                    src={project.articleHref}
                    title={`${t.profile.article_preview}: ${project.title}`}
                    loading="lazy"
                    tabindex="-1"
                    aria-hidden="true"
                  ></iframe>
                  <a href={project.articleHref} aria-label={`${t.profile.read_article}: ${project.title}`}>
                    <span>{t.profile.read_article}</span>
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M6 14 14 6"></path>
                      <path d="M7 6h7v7"></path>
                    </svg>
                  </a>
                </div>
              ) : (
                <div class="project-preview__article-empty">
                  <p>{t.profile.article_unavailable}</p>
                </div>
              )}
            </section>

            {project.notes && project.notes.length > 0 && (
              <section class="project-preview__notes" aria-label={t.profile.notes}>
                <p class="project-preview__eyebrow">{t.profile.notes}</p>
                <ul>
                  {project.notes.map(note => (
                    <li class={`project-note project-note--${note.tone ?? 'neutral'}`}>{note.text}</li>
                  ))}
                </ul>
              </section>
            )}

            {project.github && (
              <footer class="project-preview__footer">
                <a href={project.github} target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                  </svg>
                  <span>{t.profile.view_code}</span>
                </a>
              </footer>
            )}
          </aside>
        </div>
      </div>

      {project.gallery && project.gallery.length > 0 && (
        <div
          class="project-carousel"
          role="dialog"
          aria-modal="true"
          aria-labelledby={carouselTitleId}
          data-project-carousel
          hidden
        >
          <header class="project-carousel__topbar">
            <div>
              <strong id={carouselTitleId}>{t.profile.gallery}</strong>
              <span data-carousel-counter></span>
            </div>
            <button class="project-preview__close" type="button" aria-label={t.profile.close_gallery} data-carousel-close>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 6 6 18"></path>
                <path d="m6 6 12 12"></path>
              </svg>
            </button>
          </header>

          <div class="project-carousel__stage">
            <button class="project-carousel__control project-carousel__control--previous" type="button" aria-label={t.profile.previous_image} data-carousel-previous>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m15 18-6-6 6-6"></path>
              </svg>
            </button>

            <figure class="project-carousel__figure">
              <img src={project.gallery[0].src} alt={project.gallery[0].alt} data-carousel-image />
              <figcaption data-carousel-caption-output hidden></figcaption>
            </figure>

            <button class="project-carousel__control project-carousel__control--next" type="button" aria-label={t.profile.next_image} data-carousel-next>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m9 18 6-6-6-6"></path>
              </svg>
            </button>
          </div>
        </div>
      )}
    </div>
  </dialog>
</article>

<script>
  document.querySelectorAll<HTMLElement>('[data-project-card]').forEach(card => {
    if (card.dataset.projectReady === 'true') return;
    card.dataset.projectReady = 'true';

    const openButton = card.querySelector<HTMLButtonElement>('[data-project-preview-open]');
    const dialog = card.querySelector<HTMLDialogElement>('[data-project-preview-dialog]');
    const closeButton = card.querySelector<HTMLButtonElement>('[data-project-preview-close]');
    const content = card.querySelector<HTMLElement>('[data-project-preview-content]');
    const carousel = card.querySelector<HTMLElement>('[data-project-carousel]');
    const carouselItems = [...card.querySelectorAll<HTMLButtonElement>('[data-carousel-index]')];
    const carouselImage = card.querySelector<HTMLImageElement>('[data-carousel-image]');
    const carouselCaption = card.querySelector<HTMLElement>('[data-carousel-caption-output]');
    const carouselCounter = card.querySelector<HTMLElement>('[data-carousel-counter]');
    const carouselClose = card.querySelector<HTMLButtonElement>('[data-carousel-close]');
    const carouselPrevious = card.querySelector<HTMLButtonElement>('[data-carousel-previous]');
    const carouselNext = card.querySelector<HTMLButtonElement>('[data-carousel-next]');

    if (!openButton || !dialog || !closeButton) return;

    let activeIndex = 0;
    let carouselTrigger: HTMLButtonElement | null = null;

    const carouselIsOpen = () => Boolean(carousel && !carousel.hidden);

    const updateCarousel = (index: number) => {
      if (!carouselImage || carouselItems.length === 0) return;
      activeIndex = (index + carouselItems.length) % carouselItems.length;
      const item = carouselItems[activeIndex];
      const source = item.querySelector<HTMLImageElement>('img');
      if (!source) return;

      carouselImage.src = source.currentSrc || source.src;
      carouselImage.alt = source.alt;

      const caption = item.dataset.carouselCaption?.trim();
      if (carouselCaption) {
        carouselCaption.textContent = caption ?? '';
        carouselCaption.hidden = !caption;
      }
      if (carouselCounter) carouselCounter.textContent = `${activeIndex + 1} / ${carouselItems.length}`;
    };

    const openCarousel = (index: number, trigger: HTMLButtonElement) => {
      if (!carousel || !carouselClose) return;
      carouselTrigger = trigger;
      updateCarousel(index);
      carousel.hidden = false;
      if (content) content.inert = true;
      carouselClose.focus({ preventScroll: true });
    };

    const closeCarousel = (restoreFocus = true) => {
      if (!carousel) return;
      carousel.hidden = true;
      if (content) content.inert = false;
      if (restoreFocus) carouselTrigger?.focus({ preventScroll: true });
    };

    const close = () => {
      closeCarousel(false);
      if (dialog.open && typeof dialog.close === 'function') dialog.close();
      else dialog.removeAttribute('open');
    };

    openButton.addEventListener('click', () => {
      document.documentElement.classList.add('project-preview-open');
      if (typeof dialog.showModal === 'function') dialog.showModal();
      else dialog.setAttribute('open', '');
    });

    carouselItems.forEach((item, index) => {
      item.addEventListener('click', () => openCarousel(index, item));
    });
    carouselClose?.addEventListener('click', () => closeCarousel());
    carouselPrevious?.addEventListener('click', () => updateCarousel(activeIndex - 1));
    carouselNext?.addEventListener('click', () => updateCarousel(activeIndex + 1));

    closeButton.addEventListener('click', close);
    dialog.addEventListener('click', event => {
      if (event.target === dialog) close();
    });
    dialog.addEventListener('cancel', event => {
      if (carouselIsOpen()) {
        event.preventDefault();
        closeCarousel();
      }
    });
    dialog.addEventListener('keydown', event => {
      if (!carouselIsOpen()) return;
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        updateCarousel(activeIndex - 1);
      } else if (event.key === 'ArrowRight') {
        event.preventDefault();
        updateCarousel(activeIndex + 1);
      }
    });
    dialog.addEventListener('close', () => {
      closeCarousel(false);
      document.documentElement.classList.remove('project-preview-open');
      openButton.focus({ preventScroll: true });
    });
  });
</script>
