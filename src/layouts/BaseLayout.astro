---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/utils';
import { useTranslations, getLocalizedPath } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  extraStyles?: string[];
  wide?: boolean;
  availableLangs?: Lang[];
  view?: 'reading' | 'profile';
  readingPage?: boolean;
}

const {
  title,
  description,
  lang = 'es',
  extraStyles = [],
  wide = false,
  availableLangs,
  view = 'reading',
  readingPage = false,
} = Astro.props;

const t = useTranslations(lang);
const pageTitle = title || t.meta.site_title;
const pageDescription = description || t.meta.site_description;
const containerClass = wide ? 'container container--wide' : 'container';

// SEO multiidioma: canonical + alternates hreflang de las versiones que existen
const path = Astro.url.pathname;
const alternateLangs: Lang[] = availableLangs ?? ['es', 'en', 'de'];
const absoluteUrl = (p: string) => Astro.site ? new URL(p, Astro.site).href : p;
const canonicalUrl = absoluteUrl(path);
---

<!DOCTYPE html>
<html lang={lang}>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={pageDescription} />
  <meta name="author" content="José Arbelaez" />

  <!-- Open Graph -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />

  <!-- Idiomas para buscadores -->
  <link rel="canonical" href={canonicalUrl} />
  {alternateLangs.map(l => (
    <link rel="alternate" hreflang={l} href={absoluteUrl(getLocalizedPath(path, l))} />
  ))}
  {alternateLangs.includes('en') && (
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(getLocalizedPath(path, 'en'))} />
  )}

  <title>{pageTitle}</title>

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/img_astro_web.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Styles -->
  <link rel="stylesheet" href="/styles/main.css" />
  <link rel="stylesheet" href="/styles/typography.css" />
  <link rel="stylesheet" href="/styles/components.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous">
  
  {extraStyles.map(style => (
    <link rel="stylesheet" href={style} />
  ))}

  <!-- Graficas nativas en articulos -->
  <script src="/scripts/graphs.js" defer></script>

  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    (function() {
      const theme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      if (localStorage.getItem('reader-width') === 'wide') {
        document.documentElement.classList.add('reader-wide');
      }
    })();
  </script>

  <slot name="head" />
</head>

<body class:list={{ 'reading-page': readingPage }}>
  <Header lang={lang} availableLangs={availableLangs} view={view} />

  <main class={containerClass}>
    <slot />
    {readingPage && <span class="reading-end-sentinel" data-reading-end-sentinel aria-hidden="true"></span>}
  </main>

  <Footer lang={lang} reader={readingPage} />

  <slot name="scripts" />
</body>

</html>
