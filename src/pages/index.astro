---
// Root: resolve to the visitor's language, defaulting to English
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>José Arbelaez</title>
  <link rel="canonical" href="https://josearbelaez.com/en/">
  <meta http-equiv="refresh" content="0;url=/en/">
  <script>
    const lang = (navigator.language || 'en').toLowerCase();
    const target = lang.startsWith('es') ? '/es/' : lang.startsWith('de') ? '/de/' : '/en/';
    window.location.replace(target);
  </script>
</head>
<body>
</body>
</html>
