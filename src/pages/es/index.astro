---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ContentTabs from '../../components/ContentTabs.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { getCollection } from 'astro:content';

const lang: Lang = 'es';
const t = useTranslations(lang);

const allArticles = await getCollection('articles');
const publishedContent = allArticles
  .filter(a => a.data.lang === lang && !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const articles = publishedContent.filter(item => item.data.kind === 'article');
const blogPosts = publishedContent.filter(item => item.data.kind === 'blog');
---

<BaseLayout lang={lang}>
  <section class="section fade-in fade-in-1">
    <div class="intro">
      <p class="lead">{t.intro.p1}</p>
      <p>{t.intro.p2}</p>
    </div>
  </section>

  <section class="section fade-in fade-in-2" id="content">
    <ContentTabs lang={lang}>
      <div slot="articles" class="articles-list">
        {articles.length > 0
          ? articles.map(article => <ArticleCard article={article} lang={lang} />)
          : <p class="text-muted">{t.articles_page.no_articles}</p>
        }
      </div>
      <div slot="blog" class="articles-list">
        {blogPosts.length > 0
          ? blogPosts.map(post => <ArticleCard article={post} lang={lang} />)
          : <p class="text-muted">{t.blog_page.no_posts}</p>
        }
      </div>
    </ContentTabs>
  </section>
</BaseLayout>
